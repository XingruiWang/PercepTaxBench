# Copy to .env and fill in. Never commit real keys.

# Google Gemini (object description, sim placement filtering, image quality)
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional — only for VLMEvalKit-based evaluation of proprietary models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Root of your local TaxonomyVQA data (images, annotations, benchmarks)
TAXONOMY_DATA_ROOT=/path/to/Taxonomy/Data
